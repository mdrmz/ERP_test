<?php
session_start();
include("baglan.php");

// Güvenlik kontrolü
if (!isset($_SESSION["oturum"])) {
    header("Location: login.php");
    exit;
}

$mesaj = "";
$hata = "";

// --- KAYIT İŞLEMİ ---
if (isset($_POST["kaydet"])) {
    $parti_no = mysqli_real_escape_string($baglanti, trim($_POST["parti_no"]));
    $hammadde_parti_no = mysqli_real_escape_string($baglanti, $_POST["hammadde_parti_no"]);

    // Validation: Parti no duplicate kontrolü
    $parti_check = $baglanti->query("SELECT id FROM yikama_kayitlari WHERE parti_no = '$parti_no'");
    if ($parti_check && $parti_check->num_rows > 0) {
        $hata = "❌ Bu yıkama parti numarası zaten kullanılmış: $parti_no";
    }
    // Validation: Hammadde parti kontrolü
    elseif (!empty($hammadde_parti_no)) {
        $hammadde_check = $baglanti->query("SELECT id FROM hammadde_girisleri WHERE parti_no = '$hammadde_parti_no'");
        if (!$hammadde_check || $hammadde_check->num_rows == 0) {
            $hata = "❌ Bu hammadde parti numarası sistemde bulunamadı: $hammadde_parti_no";
        }
    }

    if (empty($hata)) {
        // 1. YIKAMA KAYDI
        $yikama_tarihi = $_POST["yikama_tarihi"];
        $urun_adi = $_POST["urun_adi"];
        $y_hektolitre = $_POST["y_hektolitre"];
        $y_nem = $_POST["y_nem"];
        $y_protein = $_POST["y_protein"];
        $y_sertlik = $_POST["y_sertlik"];
        $y_nisasta = $_POST["y_nisasta"];
        $tam_bugday_kg = $_POST["tam_bugday_kg"];
        $tohum_miktari_kg = $_POST["tohum_miktari_kg"];
        $su_sicakligi = $_POST["su_sicakligi"];

        $sql_yikama = "INSERT INTO yikama_kayitlari 
            (parti_no, hammadde_parti_no, yikama_tarihi, urun_adi, hektolitre, nem, protein, sertlik, nisasta, tam_bugday_kg, tohum_miktari_kg, su_sicakligi, personel) 
            VALUES ('$parti_no', '$hammadde_parti_no', '$yikama_tarihi', '$urun_adi', '$y_hektolitre', '$y_nem', '$y_protein', '$y_sertlik', '$y_nisasta', '$tam_bugday_kg', '$tohum_miktari_kg', '$su_sicakligi', '{$_SESSION["kadi"]}')";
        ;

        if ($baglanti->query($sql_yikama)) {
            $yikama_id = $baglanti->insert_id;

            // 2. AKTARMA KAYDI
            $aktarma_tarihi = $_POST["aktarma_tarihi"];
            $a_nem = $_POST["a_nem"];
            $a_su_litre = $_POST["a_su_litre"];

            $sql_aktarma = "INSERT INTO aktarma_kayitlari 
            (parti_no, yikama_id, aktarma_tarihi, nem, verilen_su_litre, personel) 
            VALUES ('$parti_no', $yikama_id, '$aktarma_tarihi', '$a_nem', '$a_su_litre', '{$_SESSION["kadi"]}')";

            if ($baglanti->query($sql_aktarma)) {
                $aktarma_id = $baglanti->insert_id;

                // 3. B1 DEĞİRMEN KAYDI
                $b1_tarihi = $_POST["b1_tarihi"];
                $b1_hektolitre = $_POST["b1_hektolitre"];
                $b1_nem = $_POST["b1_nem"];
                $b1_protein = $_POST["b1_protein"];
                $b1_sertlik = $_POST["b1_sertlik"];
                $b1_nisasta = $_POST["b1_nisasta"];
                $b1_su_litre = $_POST["b1_su_litre"];

                $sql_b1 = "INSERT INTO b1_degirmen_kayitlari 
                (parti_no, aktarma_id, uretim_tarihi, hektolitre, nem, protein, sertlik, nisasta, verilen_su_litre, personel) 
                VALUES ('$parti_no', $aktarma_id, '$b1_tarihi', '$b1_hektolitre', '$b1_nem', '$b1_protein', '$b1_sertlik', '$b1_nisasta', '$b1_su_litre', '{$_SESSION["kadi"]}')";

                if ($baglanti->query($sql_b1)) {
                    $b1_id = $baglanti->insert_id;

                    // 4. UN ÇIKIŞ KAYDI
                    $un_protein = $_POST["un_protein"] ?? null;

                    if ($un_protein) {
                        $sql_un = "INSERT INTO un_cikis_kayitlari 
                        (parti_no, b1_id, protein, personel) 
                        VALUES ('$parti_no', $b1_id, '$un_protein', '{$_SESSION["kadi"]}')";
                        $baglanti->query($sql_un);
                    }

                    $mesaj = "✅ Tüm üretim kayıtları başarıyla kaydedildi! Parti No: <strong>$parti_no</strong>";
                } else {
                    $hata = "B1 kaydı hatası: " . $baglanti->error;
                }
            } else {
                $hata = "Aktarma kaydı hatası: " . $baglanti->error;
            }
        } else {
            $hata = "Yıkama kaydı hatası: " . $baglanti->error;
        }
    }
}

// Otomatik parti no oluştur
$yeni_parti = "YK-" . date("dmy-Hi");

// Hammadde partilerini getir (lab analizi yapılmış olanları)
$hammadde_partileri = $baglanti->query("
    SELECT DISTINCT hg.parti_no, hg.tarih, hg.tedarikci, h.ad as hammadde_adi
    FROM hammadde_girisleri hg
    LEFT JOIN hammaddeler h ON hg.hammadde_id = h.id
    WHERE hg.parti_no IS NOT NULL AND hg.parti_no != ''
    ORDER BY hg.tarih DESC
    LIMIT 50
");

// Son kayıtları getir
$son_kayitlar = $baglanti->query("
    SELECT y.*, a.aktarma_tarihi, a.nem as a_nem, a.verilen_su_litre,
           b.uretim_tarihi as b1_tarihi, b.protein as b1_protein,
           u.protein as un_protein
    FROM yikama_kayitlari y
    LEFT JOIN aktarma_kayitlari a ON y.id = a.yikama_id
    LEFT JOIN b1_degirmen_kayitlari b ON a.id = b.aktarma_id
    LEFT JOIN un_cikis_kayitlari u ON b.id = u.b1_id
    ORDER BY y.id DESC LIMIT 10
");
?>

